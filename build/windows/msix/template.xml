<?xml version="1.0" encoding="utf-8"?>
<MsixPackagingToolTemplate
    xmlns="http://schemas.microsoft.com/msix/packaging/msixpackagingtool/template/2022">
    <Settings
        AllowTelemetry="false"
        ApplyACLsToPackageFiles="true"
        GenerateCommandLineFile="true"
        AllowPromptForPassword="false">
    </Settings>
    <Installer
        Path="toru.exe"
        Arguments=""
        InstallLocation="C:\Program Files\StephenSHorton\Toru">
    </Installer>
    <PackageInformation
        PackageName="Toru"
        PackageDisplayName="Toru"
        PublisherName="CN=StephenSHorton"
        PublisherDisplayName="StephenSHorton"
        Version="0.1.0.0"
        PackageDescription="macOS-style screenshot & screen recording for Windows">
        <Capabilities>
            <Capability Name="runFullTrust" />
            
        </Capabilities>
        <Applications>
            <Application
                Id="com.stephenshorton.toru"
                Description="macOS-style screenshot & screen recording for Windows"
                DisplayName="Toru"
                ExecutableName="toru.exe"
                EntryPoint="Windows.FullTrustApplication">
                
            </Application>
        </Applications>
        <Resources>
            <Resource Language="en-us" />
        </Resources>
        <Dependencies>
            <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.19041.0" />
        </Dependencies>
        <Properties>
            <Framework>false</Framework>
            <DisplayName>Toru</DisplayName>
            <PublisherDisplayName>StephenSHorton</PublisherDisplayName>
            <Description>macOS-style screenshot & screen recording for Windows</Description>
            <Logo>Assets\AppIcon.png</Logo>
        </Properties>
    </PackageInformation>
    <SaveLocation PackagePath="toru.msix" />
    <PackageIntegrity>
        <CertificatePath></CertificatePath>
    </PackageIntegrity>
</MsixPackagingToolTemplate>
